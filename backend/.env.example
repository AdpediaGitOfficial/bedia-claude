# Bediapottery backend — environment template.
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# Any secrets previously committed should be treated as compromised and rotated.

# --- Database ---
DATABASE="mongodb://127.0.0.1:27017/bediapottery"

# --- Server ---
PORT=8000
BASE_URL="http://localhost:8000"
NODE_ENV="development"

# JSON array of allowed CORS origins
CORS_URLS=["http://localhost:3000"]

CLIENT_BASE_URL=
SERVER_BASE_URL=
FRONTEND_URL=

# --- Auth / JWT ---
# Use a long, high-entropy random secret (e.g. `openssl rand -base64 48`)
JWT_SECRET=
JWT_DURATION=60d
SESSION_ID=

# --- Mail (Nodemailer / Gmail or SMTP) ---
CLIENT_MAIL=
CLIENT_PASSWORD=
MARKETING_MAIL=
MAIL_FROM=
MAIL_NAME=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CC_EMAIL=
DEFAULT_AGENT_MAIL=

# --- Object storage (AWS S3 / DigitalOcean Spaces) ---
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
FILE_BASE_URL=

# --- Stripe ---
# IMPORTANT: STRIPE_SECRET_KEY must be a SECRET key (sk_...), NOT a publishable (pk_...) key.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Places (reviews) ---
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Misc ---
XML_API=
SWAGGER_PASSWORD=
LOGIN_LIMIT=10
