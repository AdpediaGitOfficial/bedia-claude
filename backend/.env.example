# Bediapottery backend — environment template.
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# Any secrets previously committed should be treated as compromised and rotated.

# --- Database ---
DATABASE="mongodb://127.0.0.1:27017/bediapottery"

# --- Server ---
PORT=8000
# The backend's own public URL (API domain).
BASE_URL="https://bedia-claud-backend.adpedia.in"
NODE_ENV="production"

# JSON array of allowed browser origins — MUST include the site AND the dashboard.
CORS_URLS=["https://bedia-claud-frontend.adpedia.in","https://bedia-claud-dashboard.adpedia.in"]

# Public site (frontend) base URL — used by Stripe success/cancel + gift links.
CLIENT_BASE_URL="https://bedia-claud-frontend.adpedia.in"
SERVER_BASE_URL="https://bedia-claud-backend.adpedia.in"
FRONTEND_URL="https://bedia-claud-frontend.adpedia.in"

# --- Auth / JWT ---
# Use a long, high-entropy random secret (e.g. `openssl rand -base64 48`)
JWT_SECRET=
JWT_DURATION=60d
SESSION_ID=

# --- Mail (Nodemailer / Gmail or SMTP) ---
CLIENT_MAIL=
CLIENT_PASSWORD=
MARKETING_MAIL=
MAIL_FROM=
MAIL_NAME=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CC_EMAIL=
DEFAULT_AGENT_MAIL=

# --- Object storage (AWS S3 / DigitalOcean Spaces) ---
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
FILE_BASE_URL=

# --- Stripe ---
# IMPORTANT: STRIPE_SECRET_KEY must be a SECRET key (sk_...), NOT a publishable (pk_...) key.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Places (reviews) ---
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Misc ---
XML_API=
SWAGGER_PASSWORD=
LOGIN_LIMIT=10
