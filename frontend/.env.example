# Frontend (Next.js) — environment template.
# Copy to `.env.local` and fill in. Do NOT commit real values.

# Base URL of the backend API (no trailing slash). Required — the service
# layer throws if this is unset. NOTE: this is baked in at build time, so set
# it BEFORE `npm run build`.
#   local dev:  http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=https://bedia-claud-backend.adpedia.in
